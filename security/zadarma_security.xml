<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_zadarma" model="ir.module.category">
        <name>Zadarma Integration</name>
        <description>Управління інтеграцією Zadarma та автоматизацією лідів.</description>
        <sequence>100</sequence>
    </record>

    <record id="group_zadarma_user" model="res.groups">
        <name>User</name>
        <category_id ref="module_category_zadarma"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_zadarma_admin" model="res.groups">
        <name>Administrator</name>
        <category_id ref="module_category_zadarma"/>
        <field name="implied_ids" eval="[(4, ref('group_zadarma_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
