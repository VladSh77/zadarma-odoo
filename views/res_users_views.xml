<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_zadarma_inherit" model="ir.ui.view">
        <name>res.users.form.zadarma.inherit</name>
        <model>res.users</model>
        <inherit_id ref="base.view_users_form"/>
        <arch type="xml">
            <xpath expr="//page[@name='access_rights']" position="after">
                <page string="Zadarma Integration" name="zadarma">
                    <group>
                        <field name="zadarma_internal_number" placeholder="Наприклад: 101"/>
                    </group>
                </page>
            </xpath>
        </arch>
    </record>
</odoo>
