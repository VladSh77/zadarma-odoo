<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_simple_modif_zadarma" model="ir.ui.view">
        <field name="name">res.users.preferences.zadarma</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='signature']" position="before">
                <group string="Zadarma Integration">
                    <field name="zadarma_extension"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
