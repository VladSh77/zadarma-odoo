<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_zadarma_button" model="ir.ui.view">
        <name>res.partner.form.zadarma.button</name>
        <model>res.partner</model>
        <inherit_id ref="base.view_partner_form"/>
        <arch type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_zadarma_calls" type="object" class="oe_stat_button" icon="fa-phone">
                    <field name="zadarma_call_count" widget="statinfo" string="Дзвінки"/>
                </button>
            </div>
        </arch>
    </record>

    <record id="view_crm_lead_form_zadarma_button" model="ir.ui.view">
        <name>crm.lead.form.zadarma.button</name>
        <model>crm.lead</model>
        <inherit_id ref="crm.crm_lead_view_form"/>
        <arch type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_zadarma_calls" type="object" class="oe_stat_button" icon="fa-phone">
                    <field name="zadarma_call_count" widget="statinfo" string="Дзвінки"/>
                </button>
            </div>
        </arch>
    </record>
</odoo>
