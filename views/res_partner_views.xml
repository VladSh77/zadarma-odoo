<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_zadarma_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.zadarma.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Дзвінки Zadarma" name="zadarma_calls">
                    <field name="zadarma_call_ids">
                        <tree readonly="1">
                            <field name="start_time"/>
                            <field name="caller_number"/>
                            <field name="called_number"/>
                            <field name="status"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
