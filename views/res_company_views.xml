<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_company_form_zadarma_inherit" model="ir.ui.view">
            <field name="name">res.company.form.zadarma.inherit</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Zadarma Settings" name="zadarma_settings">
                        <group>
                            <field name="zadarma_api_key" password="True"/>
                            <field name="zadarma_api_secret" password="True"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
