<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_zadarma" model="ir.ui.view">
        <name>res.company.form.zadarma</name>
        <model>res.company</model>
        <inherit_id ref="base.view_company_form"/>
        <arch type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Zadarma API" name="zadarma_api">
                    <group>
                        <group string="Авторизація">
                            <field name="zadarma_api_key"/>
                            <field name="zadarma_api_secret" password="1"/>
                            <field name="zadarma_sandbox"/>
                        </group>
                        <group string="Інфраструктура">
                            <field name="zadarma_sip_mapping" placeholder="Наприклад: 101:2, 102:5"/>
                            <p class="text-muted" colspan="2">
                                Формат: SIP_ID:USER_ID. Використовується для призначення відповідального за Лід.
                            </p>
                        </group>
                    </group>
                </page>
            </xpath>
        </arch>
    </record>
</odoo>
