<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_zadarma_call_tree" model="ir.ui.view">
            <field name="name">zadarma.call.tree</field>
            <field name="model">zadarma.call</field>
            <field name="arch" type="xml">
                <tree string="Дзвінки" create="0" edit="0" delete="0" duplicate="0" decoration-info="direction == 'inbound'" decoration-success="direction == 'outbound'">
                    <field name="date_start"/>
                    <field name="phone_number"/>
                    <field name="direction"/>
                    <field name="duration" widget="float_time"/>
                    <field name="status"/>
                    <field name="partner_id"/>
                    <field name="lead_id"/>
                    <field name="recording_url" widget="url" text="Слухати"/>
                </tree>
            </field>
        </record>

        <record id="view_zadarma_call_form" model="ir.ui.view">
            <field name="name">zadarma.call.form</field>
            <field name="model">zadarma.call</field>
            <field name="arch" type="xml">
                <form string="Деталі дзвінка" create="0" edit="0" delete="0" duplicate="0">
                    <sheet>
                        <group>
                            <group string="Основна інформація">
                                <field name="date_start"/>
                                <field name="phone_number"/>
                                <field name="direction"/>
                                <field name="duration" widget="float_time"/>
                                <field name="status"/>
                            </group>
                            <group string="Зв'язки та Запис">
                                <field name="partner_id"/>
                                <field name="lead_id"/>
                                <field name="user_id"/>
                                <field name="recording_url" widget="url" text="Відкрити запис розмови"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_zadarma_calls" model="ir.actions.act_window">
            <field name="name">Дзвінки Zadarma</field>
            <field name="res_model">zadarma.call</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_zadarma_call_tree"/>
        </record>

        <menuitem id="menu_zadarma_root" name="Zadarma" sequence="10" web_icon="zadarma_odoo,static/description/icon.png"/>
        <menuitem id="menu_zadarma_calls" name="Історія дзвінків" parent="menu_zadarma_root" action="action_zadarma_calls" sequence="10"/>
    </data>
</odoo>
