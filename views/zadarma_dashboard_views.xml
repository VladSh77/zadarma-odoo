<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_zadarma_dashboard_form" model="ir.ui.view">
            <field name="name">zadarma.dashboard.form</field>
            <field name="model">zadarma.dashboard</field>
            <field name="arch" type="xml">
                <form string="Баланси" create="0" edit="0" delete="0">
                    <group>
                        <group>
                            <field name="zadarma_balance" string="Zadarma"/>
                        </group>
                        <group>
                            <field name="turbosms_balance" string="TurboSMS"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Оновити" class="btn-primary" type="object" name="action_refresh"/>
                        <button string="Закрити" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_zadarma_dashboard" model="ir.actions.server">
            <field name="name">Баланси</field>
            <field name="model_id" ref="model_zadarma_dashboard"/>
            <field name="state">code</field>
            <field name="code">action = env['zadarma.dashboard'].open_dashboard()</field>
        </record>

        <menuitem id="menu_zadarma_dashboard"
                  name="Баланси"
                  parent="menu_zadarma_root"
                  action="action_zadarma_dashboard"
                  sequence="90"/>
    </data>
</odoo>
